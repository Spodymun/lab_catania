<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="robot">

  <!--
    Minimale URDF-Konfiguration

    TF-Baum (URDF):
      base_link → chassis → imu_link
                          → top_plate → lidar_mount → velodyne
                          → wheels (x4)

    TF-Kette (zur Laufzeit, gebroadcastet von Nav2/EKF):
      map → odom → base_link
  -->

  <xacro:arg name="use_ros2_control" default="false"/>
  <xacro:arg name="sim_mode"         default="false"/>

  <!-- Core: base_link, chassis, wheels, top_plate, imu_link -->
  <xacro:include filename="robot_core.xacro"/>

  <!-- Lidar: lidar_mount + velodyne -->
  <xacro:include filename="lidar.xacro"/>
  <xacro:lidar_setup parent="top_plate" velodyne_frame="velodyne"/>

  <!-- Face: zwei Augen + Mund auf der Chassis-Vorderseite -->
  <xacro:include filename="face.xacro"/>

  <!-- ros2_control (optional) -->
  <xacro:if value="$(arg use_ros2_control)">
    <xacro:include filename="ros2_control.xacro"/>
  </xacro:if>

</robot>
